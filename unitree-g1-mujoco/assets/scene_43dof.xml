<mujoco model="g1_43dof scene">
  <include file="g1_29dof_with_hand.xml"/>
  <!-- Note that the hand model in g1_29dof_with_hand.xml is not stable for simulation. -->

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <mesh name="cup" file="../cup.stl" scale="0.0013 0.0013 0.0013" />
    <mesh name="chaleira" file="../chaleira.obj" scale="0.2 0.2 0.2" />
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <!-- Site -->
    <site name="com_marker" pos="0.1 0 0" size="0.05" rgba="1 0 0 1" type="sphere"/>

  <body name="mesa" pos="0.45 0 0.45">
      <geom name="geometria_mesa" type="box" size="0.2 0.6 0.45" rgba="0.6 0.4 0.2 1" friction="1 0.005 0.0001"/>
      
      <geom name="borda_fundo" type="box" size="0.01 0.6 0.02" pos="0.19 0 0.47" rgba="0.5 0.3 0.1 1" friction="1 0.005 0.0001"/>
      <geom name="borda_esquerda" type="box" size="0.2 0.01 0.02" pos="0 0.59 0.47" rgba="0.5 0.3 0.1 1" friction="1 0.005 0.0001"/>
      <geom name="borda_direita" type="box" size="0.2 0.01 0.02" pos="0 -0.59 0.47" rgba="0.5 0.3 0.1 1" friction="1 0.005 0.0001"/>

      <body name="corpo_botao" pos="0 0.3 0.47">
        <joint name="junta_botao" type="slide" axis="0 0 1" range="-0.015 0" springref="0" stiffness="100" damping="5"/>
        <geom name="geometria_botao" type="cylinder" size="0.03 0.02" rgba="0 1 0 1" mass="0.01" friction="1 0.005 0.0001"/>
      </body>
    </body>

    <!--<body name="objeto_customizado2" pos="0.40 0.05 0.98">
      <freejoint name="junta_livre_bloco2"/>
      <geom name="geometria_bloco2" type="mesh" mesh="chaleira" rgba="0.8 0.1 0.1 1" mass="0.700" friction="3 0.05 0.0001"/>
    </body>-->

    <body name="objeto_customizado" pos="0.35 -0.05 0.90">
      <freejoint name="junta_livre_bloco"/>
      <geom name="geometria_bloco" type="mesh" mesh="cup" rgba="0.8 0.1 0.1 1" mass="0.1" friction="1 0.005 0.0001"/>
    </body>
    
    <!-- Third-person camera for visualization -->
    <camera name="global_view" pos="2.910 -5.040 3.860" xyaxes="0.866 0.500 0.000 -0.250 0.433 0.866" fovy="45"/>
  </worldbody>

  <default>
    <geom friction="1.0"/>
  </default>
</mujoco>
